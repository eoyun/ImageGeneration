# Unix submit description file
Universe = vanilla
Executable = ./Scr/251112_v2/DYto2L_2J_MLM/test.sh
request_memory = 1000
should_transfer_files   = Yes
arguments = $(ProcId)
output = ./Scr/251112_v2/DYto2L_2J_MLM/log/$(ProcId).out
error = ./Scr/251112_v2/DYto2L_2J_MLM/log/$(ProcId).err
log = ./Scr/251112_v2/DYto2L_2J_MLM/log/$(ProcId).log
x509userproxy = /u/user/eoyun/proxy.cert
+MaxRuntime = 36000
+JobBatchName = "251112_v2_DYto2L_2J_MLM"
Queue 30
